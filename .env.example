# Chat LLM (model-agnostic adapter — OpenAI-compatible API)
CHAT_PROVIDER=openai
CHAT_API_KEY=sk-your-chat-key-here
CHAT_MODEL=gpt-4o-mini
CHAT_BASE_URL=

# Embeddings (RAG — OpenAI-compatible API)
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=sk-your-embedding-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Session
SESSION_TTL_SECONDS=3600

# OpenStreetMap / Overpass (Phase 1)
# OVERPASS_URL is preferred; OVERPASS_API_URL remains accepted for compatibility.
OVERPASS_URL=https://overpass-api.de/api/interpreter
# Comma-separated mirrors tried after primary on 429/502/503/504 (after retries).
OVERPASS_MIRRORS=https://lz4.overpass-api.de/api/interpreter,https://overpass.kumi.systems/api/interpreter
OSM_CACHE_DIR=data/cache/osm
# Successful live POI lookups are cached per city to reduce Overpass traffic in development.
POI_CITY_CACHE_TTL_SECONDS=86400

# Chroma vector store (Phase 2 RAG)
CHROMA_PERSIST_DIR=data/rag/index/chroma
CHROMA_COLLECTION_NAME=travel_guidance

# Speech-to-text (Phase 5 — browser Web Speech API needs no key; optional cloud STT)
STT_PROVIDER=browser
DEEPGRAM_API_KEY=

# n8n export webhook (Phase 8)
# Production webhook URL (activate workflow first). Example:
# https://<your-n8n-host>/webhook/export-itinerary
N8N_EXPORT_WEBHOOK_URL=

# Production CORS — comma-separated frontend origins (HTTPS in production)
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Shared secret for workflows/export_itinerary_http.json → POST /api/internal/export/render
EXPORT_RENDER_SECRET=

# --- Frontend (Vite) — set in Vercel/hosting dashboard, not on the API server ---
# VITE_API_BASE_URL=https://your-api.onrender.com
