# LLM (model-agnostic adapter — OpenAI-compatible API)
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Speech-to-text (Phase 5 — browser Web Speech API needs no key; optional cloud STT)
STT_PROVIDER=browser
DEEPGRAM_API_KEY=

# OpenStreetMap / Overpass (Phase 1)
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# n8n export webhook (Phase 8)
N8N_EXPORT_WEBHOOK_URL=

# Session
SESSION_TTL_SECONDS=3600
